{
  "name": "lightedit",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:baseline": "vitest run src/qualityBaseline.test.tsx",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "qa": "npm run test:unit && npm run build && npm run check:rust && npm run test:rust",
    "visual:baseline": "node qa/visual-baseline/print-scenarios.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  }
}
