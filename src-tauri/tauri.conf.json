{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LightEdit",
  "version": "0.4.0",
  "identifier": "com.lightedit.app",
  "build": {
    "beforeDevCommand": "npm run dev -- --port 5173 --strictPort",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "LightEdit",
        "width": 800,
        "height": 560,
        "minWidth": 760,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 14,
          "y": 17
        },
        "hiddenTitle": true,
        "backgroundColor": "#fffaf0",
        "shadow": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
